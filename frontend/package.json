{
  "name": "medtrackhub",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.9.0 <23"
  },
  "scripts": {
    "postinstall": "npm run setup:pdfjs",
    "dev": "npm run setup:pdfjs && next dev",
    "setup:pdfjs": "node scripts/setup-pdfjs.js",
    "build": "npm run setup:pdfjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "e2e": "playwright test",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "health-check": "node scripts/health-check.js",
    "check:routes": "node scripts/check-routes.js",
    "restructure": "powershell -ExecutionPolicy Bypass -File ./scripts/restructure.ps1",
    "restructure:dry-run": "powershell -ExecutionPolicy Bypass -File ./scripts/restructure.ps1 -DryRun -Verbose",
    "restructure:phase1": "powershell -ExecutionPolicy Bypass -File ./scripts/restructure.ps1 -Phase 1",
    "restructure:phase2": "powershell -ExecutionPolicy Bypass -File ./scripts/restructure.ps1 -Phase 2",
    "restructure:phase3": "powershell -ExecutionPolicy Bypass -File ./scripts/restructure.ps1 -Phase 3",
    "restructure:phase4": "powershell -ExecutionPolicy Bypass -File ./scripts/restructure.ps1 -Phase 4",
    "restructure:verbose": "powershell -ExecutionPolicy Bypass -File ./scripts/restructure.ps1 -Verbose",
    "rollback": "powershell -ExecutionPolicy Bypass -File ./rollback.ps1"
  },
