  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "imports": {
    "#common/*": "./src/common/*",
    "#infrastructure/*": "./src/infrastructure/*",
    "#modules/*": "./src/modules/*"
  },
  "scripts": {
    "build": "pnpm run generate:proto && nest build",
    "check": "pnpm tsc --noEmit && pnpm run validate:circular && pnpm run validate:swagger",
    "start": "node dist/src/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "debug:swagger": "nest build && node dist/src/main",
    "format": "prettier --write \"{src,apps,libs,test}/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json",
    "test:all": "pnpm run test && pnpm run test:e2e && pnpm run test:integration",
    "prisma:generate": "prisma generate",
    "prisma:migrate": " prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:db:push": "prisma db push",
    "prisma:db:pull": "prisma db pull",
    "seed": "tsx prisma/seeds/seed_roles.ts && tsx prisma/seeds/seed.ts && tsx prisma/seeds/courses.seed.ts",
    "docker:dev": "docker-compose up server-dev --build",
    "docker:dev:clean": "docker-compose down -v && docker-compose up server-dev --build",
    "docker:logs": "docker-compose logs -f server-dev",
    "docker:shell": "docker-compose exec server-dev sh",
    "docker:db": "docker-compose up -d postgres",
    "docker:redis": "docker-compose up -d redis",
    "docker:services": "docker-compose up -d postgres redis",
    "prisma:studio:docker": "docker-compose exec server pnpm prisma studio --hostname 0.0.0.0",
    "prisma:migrate:docker": "docker-compose exec server-dev pnpm prisma migrate dev",
    "prisma:reset:docker": "docker-compose exec server-dev pnpm prisma migrate reset",
    "docker:down": "docker-compose down",
    "docker:down:volumes": "docker-compose down -v",
    "generate:proto": "node -e \"require('fs').mkdirSync('src/generated/grpc', { recursive: true })\" && pnpm exec -- grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=\"C:\\\\Users\\\\user\\\\medical\\\\backend\\\\node_modules\\\\.bin\\\\protoc-gen-ts_proto.CMD\" --ts_proto_out=src/generated/grpc --ts_proto_opt=nestJs=true,outputServices=grpc-js -I ../protos ../protos/*.proto",
    "convert:extract": "ts-node scripts/convert_extract_to_seed.ts",
    "backend:upload-files": "ts-node scripts/upload_files_to_s3.ts",
    "validate:circular": "madge --circular src/",
    "validate:swagger": "node -r ts-node/register scripts/validate-swagger.ts",
    "validate:types": "tsc --noEmit",
    "validate:dto": "pnpm run validate:types && pnpm run validate:circular && pnpm run validate:swagger",
    "precommit": "pnpm run lint && pnpm run validate:types && pnpm run validate:circular"
  },
