generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  engineType      = "library"
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

model Question {
  id                    String                 @id @default(uuid())
  text                  String                 @db.VarChar(1000)
  type                  QuestionType           @default(multiple_choice)
  difficulty            QuestionDifficulty     @default(medium)
  category              QuestionCategory       @default(general)
  explanation           String?
  conceptsCovered       String[]               @map("concepts_covered")
  tags                  String[]
  points                Int                    @default(1)
  metadata              Json?
  isMultipleChoice      Boolean                @default(true) @map("is_multiple_choice")
  choices               Json?
  usageCount            Int                    @default(0) @map("usage_count")
  successRate           Float                  @default(0) @map("success_rate")
  averageTime           Int                    @default(0) @map("average_time")
  discriminationIndex   Float?                 @map("discrimination_index")
  difficultyIndex       Float?                 @map("difficulty_index")
  guessingParameter     Float?                 @map("guessing_parameter")
  discrimination        Float                  @default(0)
  guessing              Float                  @default(0)
  averageScore          Float?                 @default(0) @map("average_score")
  isActive              Boolean                @default(true) @map("is_active")
  createdBy             String?                @map("created_by")
  courseId              String?                @map("course_id")
  unitId                String?                @map("unit_id")
  topicIds              String[]               @map("topic_ids")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  flashcards            Flashcard[]
  instructorOverrides   InstructorOverride[]
  questionFlags         QuestionFlag[]
  options               Option[]
  questionStats         QuestionStats?
  course                Course?                @relation(fields: [courseId], references: [id])
  unit                  Unit?                  @relation(fields: [unitId], references: [id])
  quizQuestions         QuizQuestion[]
  rapidReviewAnswers    RapidReviewAnswer[]
  spacedRepetitionCards SpacedRepetitionCard[]
  userResponses         UserResponse[]

  @@index([courseId])
  @@index([unitId])
  @@index([category])
  @@index([type])
  @@index([difficulty])
  @@map("questions")
}

model Option {
  id          String   @id @default(uuid())
  questionId  String   @map("question_id")
  text        String
  isCorrect   Boolean  @default(false) @map("is_correct")
  explanation String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  question    Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@map("question_options")
}

model UserActivity {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        UserActivityType
  description String?
  details     Json?
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([userId, createdAt])
  @@map("user_activities")
}

model UnitAccess {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  unitId     String   @map("unit_id")
  createdAt  DateTime @default(now()) @map("created_at")
  accessedAt DateTime @default(now()) @map("accessed_at")
  timeSpent  Int?     @default(0) @map("time_spent")
  unit       Unit     @relation(fields: [unitId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([unitId])
  @@map("unit_accesses")
}

model Quiz {
  id                   String                   @id @default(uuid())
  title                String                   @db.VarChar(255)
  description          String?
  instructions         String?
  timeLimit            Int?                     @map("time_limit")
  maxAttempts          Int?                     @default(3) @map("max_attempts")
  passingScore         Float?                   @default(70.0) @map("passing_score")
  isPublished          Boolean                  @default(false) @map("is_published")
  publishedAt          DateTime?                @map("published_at")
  expiresAt            DateTime?                @map("expires_at")
  availableFrom        DateTime?                @map("available_from")
  availableUntil       DateTime?                @map("available_until")
  questionCount        Int                      @default(0) @map("question_count")
  shuffleQuestions     Boolean                  @default(false) @map("shuffle_questions")
  showResults          Boolean                  @default(true) @map("show_results")
  isAdaptive           Boolean                  @default(false) @map("is_adaptive")
  adaptiveConfig       Json?                    @map("adaptive_config")
  categoryId           String?                  @map("category_id")
  unitId               String?                  @map("unit_id")
  topicId              String?                  @map("topic_id")
  createdBy            String                   @map("created_by")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  /// Full-text search vector for PostgreSQL tsvector queries (@@ operator).
  /// Automatically updated by trigger on INSERT/UPDATE.
  fts                  Unsupported("tsvector")?
  autoGeneratedQuizzes AutoGeneratedQuiz[]      @relation("AutoGeneratedQuizzes")
  flashcardResults     FlashcardResult[]
  attempts             QuizAttempt[]
  questions            QuizQuestion[]
  category             CourseCategory?          @relation(fields: [categoryId], references: [id])
  topic                Topic?                   @relation(fields: [topicId], references: [id])
  unit                 Unit?                    @relation(fields: [unitId], references: [id])
  rubric               Rubric?
  userQuizProgress     UserQuizProgress[]

  @@index([unitId])
  @@index([topicId])
  @@index([categoryId])
  @@index([createdBy])
  @@index([fts], type: Gin)
  @@index([title])
  @@map("quizzes")
}

model AutoGeneratedQuiz {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  quizId           String    @map("quiz_id")
  weaknessTopicId  String    @map("weakness_topic_id")
  detectedAt       DateTime  @default(now()) @map("detected_at")
  completedAt      DateTime? @map("completed_at")
  riskLevel        String    @map("risk_level")
  scoreImprovement Float?    @map("score_improvement")
  createdAt        DateTime  @default(now()) @map("created_at")
  quiz             Quiz      @relation("AutoGeneratedQuizzes", fields: [quizId], references: [id])
  user             User      @relation(fields: [userId], references: [id])
  topic            Topic     @relation("WeaknessTopics", fields: [weaknessTopicId], references: [id])

  @@unique([userId, quizId])
  @@index([userId])
  @@index([detectedAt])
  @@index([completedAt])
  @@index([riskLevel])
  @@map("auto_generated_quizzes")
}

model QuizQuestion {
  id         String   @id @default(uuid())
  quizId     String   @map("quiz_id")
  questionId String   @map("question_id")
  order      Int      @default(0)
  points     Int      @default(1)
  isRequired Boolean  @default(true) @map("is_required")
  question   Question @relation(fields: [questionId], references: [id])
  quiz       Quiz     @relation(fields: [quizId], references: [id])

  @@unique([quizId, questionId])
  @@index([quizId])
  @@index([questionId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  quizId         String         @map("quiz_id")
  startedAt      DateTime       @default(now()) @map("started_at")
  completedAt    DateTime?      @map("completed_at")
  score          Float          @default(0)
  maxScore       Float          @default(0) @map("max_score")
  percentage     Float          @default(0)
  timeSpent      Int            @default(0) @map("time_spent")
  timeTaken      Int?           @map("time_taken")
  isPassed       Boolean        @default(false) @map("is_passed")
  correctAnswers Int            @default(0) @map("correct_answers")
  totalQuestions Int            @default(0) @map("total_questions")
  answers        Json?
  feedback       Json?
  createdAt      DateTime       @default(now()) @map("created_at")
  quiz           Quiz           @relation(fields: [quizId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  responses      UserResponse[]

  @@index([userId])
  @@index([quizId])
  @@index([startedAt])
  @@index([completedAt])
  @@map("quiz_attempts")
}

model UserResponse {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  questionId   String      @map("question_id")
  attemptId    String      @map("attempt_id")
  answer       Json
  isCorrect    Boolean     @default(false) @map("is_correct")
  score        Float?      @default(0)
  timeSpent    Int         @default(0) @map("time_spent")
  responseTime Int?        @map("response_time")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  attempt      QuizAttempt @relation(fields: [attemptId], references: [id])
  question     Question    @relation(fields: [questionId], references: [id])
  user         User        @relation(fields: [userId], references: [id])

  @@unique([userId, questionId], name: "user_response_question_unique")
  @@index([userId])
  @@index([questionId])
  @@index([attemptId])
  @@map("user_responses")
}

model Flashcard {
  id           String                  @id @default(uuid())
  questionId   String?                 @map("question_id")
  front        String
  back         String
  hints        String[]
  tags         String[]
  difficulty   QuestionDifficulty      @default(medium)
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  question     Question?               @relation(fields: [questionId], references: [id])
  userProgress UserFlashcardProgress[]

  @@index([questionId])
  @@map("flashcards")
}

model UserFlashcardProgress {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  flashcardId   String    @map("flashcard_id")
  easeFactor    Float     @default(2.5) @map("ease_factor")
  interval      Int       @default(0)
  repetitions   Int       @default(0)
  correctStreak Int       @default(0) @map("correct_streak")
  lastReview    DateTime? @map("last_review")
  nextReview    DateTime  @default(now()) @map("next_review")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  flashcard     Flashcard @relation(fields: [flashcardId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, flashcardId])
  @@index([userId])
  @@index([flashcardId])
  @@index([nextReview])
  @@map("user_flashcard_progress")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique @db.VarChar(255)
  firstName               String?                  @map("first_name") @db.VarChar(255)
  lastName                String?                  @map("last_name") @db.VarChar(255)
  username                String?                  @unique @db.VarChar(100)
  password                String?                  @db.VarChar(255)
  phoneNumber             String?                  @map("phone_number") @db.VarChar(50)
  profileImage            String?                  @map("profile_image") @db.VarChar(2048)
  bio                     String?
  location                String?                  @db.VarChar(255)
  yearOfExperience        Int?                     @map("year_of_experience")
  streakDays              Int                      @default(0) @map("streak_days")
  preferences             Json?
  guidanceLevel           GuidanceLevel?           @map("guidance_level")
  guidanceLevelOverride   Boolean                  @default(false) @map("guidance_level_override")
  isActive                Boolean                  @default(true) @map("is_active")
  isLocked                Boolean                  @default(false) @map("is_locked")
  lockedUntil             DateTime?                @map("locked_until")
  failedLoginAttempts     Int                      @default(0) @map("failed_login_attempts")
  points                  Int                      @default(0)
  rewards                 Json                     @default("[]")
  specialization          String?
  lastLogin               DateTime?                @map("last_login")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  enrollmentType          EnrollmentType           @default(self_paced) @map("enrollment_type")
  fts                     Unsupported("tsvector")?
  assessmentProgresses    AssessmentProgress[]
  autoGeneratedQuizzes    AutoGeneratedQuiz[]
  caseAttempts            CaseAttempt[]
  chatMessages            ChatMessage[]
  chatSessions            ChatSession[]
  enrollments             CourseEnrollment[]
  instructingCourses      CourseInstructor[]
  courseProgress          CourseProgress[]
  coursesCreated          Course[]                 @relation("CourseCreator")
  cpdActivities           CPDActivity[]
  cpdCycles               CPDCycle[]
  deadlines               Deadline[]               @relation("UserDeadlines")
  discussionMessages      DiscussionMessage[]
  EmailVerificationToken  EmailVerificationToken?
  experimentAssignments   ExperimentAssignment[]
  File                    File[]
  flashcardResults        FlashcardResult[]
  instructorOverrides     InstructorOverride[]
  LearningGoalProgress    LearningGoalProgress[]
  learningGoals           LearningGoal[]
  learningHistory         LearningHistory[]
  learningPathProgress    LearningPathProgress[]
  learningSuggestions     LearningSuggestion[]
  materialEngagements     MaterialEngagement[]
  materialEvents          MaterialEvent[]
  materialNotes           MaterialNote[]
  materialShares          MaterialShare[]
  materials               Material[]
  notifications           Notification[]
  predictionAudits        PredictionAudit[]
  predictionValidations   PredictionValidation[]
  questionFlags           QuestionFlag[]
  quizAttempts            QuizAttempt[]
  rapidReviewSessions     RapidReviewSession[]
  recommendations         Recommendation[]
  scheduleEvents          ScheduleEvent[]
  securityAudits          SecurityAudit[]
  securityEvents          SecurityEvent[]
  skillTrajectories       SkillTrajectory[]
  spacedRepetitionCards   SpacedRepetitionCard[]
  studentInteractions     StudentInteraction[]
  studyEvents             StudyEvent[]
  studyGroups             StudyGroupMember[]
  studySessions           StudySession[]
  syncLogs                SyncLog[]
  progress                Progress[]
  unitAccesses            UnitAccess[]
  unitCompletions         UnitCompletion[]
  unitProgress            UnitProgress[]
  userActivities          UserActivity[]
  userBadges              UserBadge[]              @relation("UserUserBadges")
  userFlashcardProgresses UserFlashcardProgress[]
  analytics               UserLearningAnalytics?
  userQuizProgress        UserQuizProgress[]
  UserResponse            UserResponse[]
  userRoles               UserRole[]
  securitySettings        UserSecuritySettings?
  sessions                UserSession[]
  userSkillStates         UserSkillState[]
  weeklyDigests           WeeklyDigest[]
  xapiStatements          XapiStatement[]

  @@index([email])
  @@index([username])
  @@index([createdAt])
  @@index([fts], type: Gin)
  @@map("users")
}

model UserSkillState {
  userId      String   @map("user_id")
  skillId     String   @map("skill_id")
  pKnown      Float    @map("p_known")
  lastUpdated DateTime @default(now()) @map("last_updated")
  attempts    Int      @default(0)
  skill       Topic    @relation(fields: [skillId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@id([userId, skillId])
  @@map("user_skill_states")
}

model Role {
  id             String           @id @default(uuid())
  name           RoleName         @unique
  description    String?
  isSystem       Boolean          @default(false) @map("is_system")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  color          String?          @db.VarChar(50)
  hierarchyLevel Int              @default(0) @map("hierarchy_level")
  isActive       Boolean          @default(true) @map("is_active")
  permissions    RolePermission[]
  userRoles      UserRole[]

  @@index([name])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique @db.VarChar(100)
  description String?
  resource    String           @db.VarChar(100)
  action      String           @db.VarChar(100)
  category    String?          @db.VarChar(100)
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@index([name])
  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model File {
  id           String     @id @default(uuid())
  filename     String
  mimetype     String
  size         Int
  key          String?
  hash         String?
  uploadedById String?    @map("uploaded_by_id")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt @map("updated_at")
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id])
  materials    Material[]

  @@index([hash])
  @@index([uploadedById])
  @@map("files")
}

model UserSecuritySettings {
  id                       String    @id @default(uuid())
  userId                   String    @unique @map("user_id")
  twoFactorEnabled         Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret          String?   @map("two_factor_secret")
  loginNotifications       Boolean   @default(true) @map("login_notifications")
  sessionTimeout           Int       @default(3600) @map("session_timeout")
  passwordLastChanged      DateTime  @default(now()) @map("password_last_changed")
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  isEmailVerified          Boolean   @default(false)
  backupCodes              String[]
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  acceptTerms              Boolean   @default(false) @map("accept_terms")
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_security_settings")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}

model UserSession {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  token        String    @unique
  deviceId     String?
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  revokedAt    DateTime? @map("revoked_at")
  isActive     Boolean   @default(true) @map("is_active")
  lastAccessed DateTime? @map("last_accessed")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("user_sessions")
}

model SecurityEvent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  eventType   String   @map("event_type") @db.VarChar(100)
  description String
  details     Json?    @map("eventData")
  timestamp   DateTime @default(now())
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  severity    String?  @db.VarChar(50)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("security_events")
}

model SecurityAudit {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String   @db.VarChar(100)
  resource    String   @db.VarChar(100)
  details     Json?
  isSensitive Boolean  @default(false) @map("is_sensitive")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  timestamp   DateTime @default(now())
  status      String?
  role        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  User        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("security_audits")
}

model CourseCategory {
  id            String           @id @default(uuid())
  name          String           @db.VarChar(255)
  slug          String           @unique @db.VarChar(100)
  description   String?
  parentId      String?          @map("parent_id")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  parent        CourseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      CourseCategory[] @relation("CategoryHierarchy")
  courses       Course[]
  learningPaths LearningPath[]
  quizzes       Quiz[]

  @@index([slug])
  @@index([parentId])
  @@map("course_categories")
}

model Course {
  id                String                   @id @default(uuid())
  name              String                   @db.VarChar(255)
  title             String?                  @db.VarChar(255)
  code              String?                  @unique @db.VarChar(50)
  description       String?
  difficulty        CourseDifficulty         @default(beginner)
  status            CourseStatus             @default(draft)
  categoryId        String?                  @map("category_id")
  createdById       String?                  @map("created_by_id")
  estimatedHours    Int?                     @default(0) @map("estimated_hours")
  tags              String[]                 @default([])
  rating            Float?                   @default(0)
  price             Float?                   @default(0)
  enrollmentCount   Int?                     @default(0) @map("enrollment_count")
  isFeatured        Boolean                  @default(false) @map("is_featured")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  /// Full-text search vector for PostgreSQL tsvector queries (@@ operator).
  /// Automatically updated by trigger on INSERT/UPDATE.
  /// Supports weighted search across title(A), name(A), description(B), tags(C).
  /// Marked Unsupported because Prisma lacks native tsvector support.
  /// Use in raw queries only: prisma.$queryRaw`WHERE fts @@ plainto_tsquery(...)`
  fts               Unsupported("tsvector")?
  clinicalCases     ClinicalCase[]
  enrollments       CourseEnrollment[]
  instructors       CourseInstructor[]
  prerequisites     CoursePrerequisite[]     @relation("PrerequisiteTo")
  isPrerequisiteFor CoursePrerequisite[]     @relation("PrerequisiteFor")
  courseProgress    CourseProgress[]
  category          CourseCategory?          @relation(fields: [categoryId], references: [id])
  createdBy         User?                    @relation("CourseCreator", fields: [createdById], references: [id])
  deadlines         Deadline[]               @relation("CourseDeadlines")
  LearningGoal      LearningGoal[]
  materials         Material[]
  Question          Question[]
  scheduleEvents    ScheduleEvent[]
  progress          Progress[]
  units             Unit[]

  @@index([code])
  @@index([categoryId])
  @@index([status])
  @@index([fts], type: Gin)
  @@index([difficulty])
  @@index([name])
  @@index([title])
  @@map("courses")
}

model CoursePrerequisite {
  courseId       String           @map("course_id")
  prerequisiteId String           @map("prerequisite_id")
  type           PrerequisiteType @default(required)
  course         Course           @relation("PrerequisiteTo", fields: [courseId], references: [id])
  prerequisite   Course           @relation("PrerequisiteFor", fields: [prerequisiteId], references: [id])

  @@id([courseId, prerequisiteId])
  @@map("course_prerequisites")
}

model Unit {
  id                      String                   @id @default(uuid())
  name                    String                   @db.VarChar(255)
  title                   String?
  description             String?
  order                   Int
