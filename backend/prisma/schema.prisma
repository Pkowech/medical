model StudyGroup {
  id          String             @id @default(uuid())
  name        String
  description String?
  type        StudyGroupType
  privacy     StudyGroupPrivacy
  maxMembers  Int                @map("max_members")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  status      StudyGroupStatus
  metadata    Json?
  inviteCode  String             @unique @map("invite_code")
  discussions GroupDiscussion[]  @relation("StudyGroupDiscussions")
  members     StudyGroupMember[] @relation("StudyGroupMembers")

  @@index([status])
  @@index([type])
  @@map("study_groups")
}

model StudyGroupMember {
  id           String       @id @default(uuid())
  studyGroupId String       @map("study_group_id")
  userId       String       @map("user_id")
  role         MemberRole
  status       MemberStatus
  joinedAt     DateTime     @default(now()) @map("joined_at")
  metadata     Json?
  studyGroup   StudyGroup   @relation("StudyGroupMembers", fields: [studyGroupId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyGroupId])
  @@index([userId])
  @@index([studyGroupId])
  @@map("study_group_members")
}

model GroupDiscussion {
  id           String              @id @default(uuid())
  title        String
  type         DiscussionType
  studyGroupId String              @map("study_group_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  status       DiscussionStatus
  metadata     Json?
  messages     DiscussionMessage[] @relation("DiscussionMessages")
  studyGroup   StudyGroup          @relation("StudyGroupDiscussions", fields: [studyGroupId], references: [id], onDelete: Cascade)

  @@index([studyGroupId])
  @@index([status])
  @@map("group_discussions")
}

model DiscussionMessage {
  id           String              @id @default(uuid())
  content      String
  type         MessageType
  discussionId String              @map("discussion_id")
  userId       String              @map("user_id")
  replyToId    String?             @map("reply_to_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  metadata     Json?
  discussion   GroupDiscussion     @relation("DiscussionMessages", fields: [discussionId], references: [id], onDelete: Cascade)
  replyTo      DiscussionMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      DiscussionMessage[] @relation("MessageReplies")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([userId])
  @@index([replyToId])
  @@map("discussion_messages")
}

model StudySession {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  topicId        String?   @map("topic_id")
  materialId     String?   @map("material_id")
  startTime      DateTime  @default(now()) @map("start_time")
  endTime        DateTime? @map("end_time")
  duration       Int?
  focusScore     Int       @default(0) @map("focus_score")
  activities     Json?
  notes          String?
  metadata       Json?
  isValid        Boolean   @default(true) @map("is_valid")
  invalidReason  String?   @map("invalid_reason")
  learningGain   Float?    @map("learning_gain")
  quizAttemptIds String[]  @map("quiz_attempt_ids")
  material       Material? @relation(fields: [materialId], references: [id])
  topic          Topic?    @relation(fields: [topicId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([topicId])
  @@index([materialId])
  @@index([userId, startTime])
  @@map("study_sessions")
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  title     String        @db.VarChar(255)
  topic     String?       @db.VarChar(100)
  context   String?
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  userId    String      @map("user_id")
  content   String
  role      MessageRole
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Notification {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  message     String
  type        String?              @db.VarChar(50)
  read        Boolean              @default(false)
  priority    NotificationPriority @default(low)
  metadata    Json?
  createdAt   DateTime             @default(now()) @map("created_at")
  severity    String?              @db.VarChar(20)
  throttled   Boolean              @default(false)
  sentViaPush Boolean              @default(false) @map("sent_via_push")
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([priority])
  @@index([userId, createdAt(sort: Desc)])
  @@index([severity])
  @@map("notifications")
}

model WeeklyDigest {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  weekStartDate DateTime     @map("week_start_date")
  weekEndDate   DateTime     @map("week_end_date")
  status        DigestStatus @default(pending)
  content       Json
  isSent        Boolean      @default(false) @map("is_sent")
  sentAt        DateTime?    @map("sent_at")
  readAt        DateTime?    @map("read_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([userId])
  @@index([weekStartDate])
  @@index([status])
  @@map("weekly_digests")
}

model CPDCycle {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  name           String        @db.VarChar(255)
  startDate      DateTime      @map("start_date")
  endDate        DateTime      @map("end_date")
  requiredPoints Int           @default(0) @map("required_points")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  activities     CPDActivity[]
  user           User          @relation(fields: [userId], references: [id])

  @@index([isActive])
  @@index([startDate])
  @@index([endDate])
  @@map("cpd_cycles")
}

model CPDActivity {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  activityDate DateTime        @map("activity_date")
  activityType CPDActivityType @map("activity_type")
  points       Int             @default(0)
  description  String?
  materialId   String?         @map("material_id")
  cycleId      String?         @map("cycle_id")
  verified     Boolean         @default(false) @map("is_verified")
  metadata     Json?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  cycle        CPDCycle?       @relation(fields: [cycleId], references: [id])
  material     Material?       @relation(fields: [materialId], references: [id])
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityDate])
  @@index([cycleId])
  @@index([activityType])
  @@index([verified])
  @@map("cpd_activities")
}

model UnitRelation {
  id           String   @id @default(uuid())
  sourceUnitId String   @map("source_unit_id")
  targetUnitId String   @map("target_unit_id")
  relationType String   @map("relation_type")
  score        Float
  algorithm    String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  sourceUnit   Unit     @relation("SourceUnitRelations", fields: [sourceUnitId], references: [id], onDelete: Cascade)
  targetUnit   Unit     @relation("TargetUnitRelations", fields: [targetUnitId], references: [id], onDelete: Cascade)

  @@unique([sourceUnitId, targetUnitId, relationType])
  @@index([sourceUnitId])
  @@index([targetUnitId])
  @@index([relationType])
  @@map("unit_relations")
}

model StudentInteraction {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  unitId          String   @map("unit_id")
  interactionType String   @map("interaction_type")
  score           Float    @default(0)
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([unitId])
  @@index([interactionType])
  @@map("student_interactions")
}

model FlashcardResult {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  unitId      String   @map("unit_id")
  quizId      String?  @map("quiz_id")
  score       Float
  passed      Boolean
  attemptedAt DateTime @default(now()) @map("attempted_at")
  metadata    Json?
  quiz        Quiz?    @relation(fields: [quizId], references: [id])
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([unitId])
  @@index([quizId])
  @@map("flashcard_results")
}

model Recommendation {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  recommendedUnitId String   @map("recommended_unit_id")
  sourceUnitId      String?  @map("source_unit_id")
  score             Float
  reason            String
  algorithm         String
  isDismissed       Boolean  @default(false) @map("is_dismissed")
  isEngaged         Boolean  @default(false) @map("is_engaged")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  recommendedUnit   Unit     @relation("RecommendedUnit", fields: [recommendedUnitId], references: [id], onDelete: Cascade)
  sourceUnit        Unit?    @relation("SourceUnit", fields: [sourceUnitId], references: [id])
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recommendedUnitId])
  @@index([sourceUnitId])
  @@index([algorithm])
  @@map("recommendations")
}

model MLModel {
  id               String    @id @default(uuid())
  name             String
  version          String
  type             String
  path             String
  trainingDataPath String?   @map("training_data_path")
  metrics          Json?
  trainedAt        DateTime  @default(now()) @map("trained_at")
  lastEvaluatedAt  DateTime? @map("last_evaluated_at")
  isActive         Boolean   @default(false) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([name])
  @@index([type])
  @@index([isActive])
  @@map("ml_models")
}

model Rubric {
  id        String   @id @default(uuid())
  quizId    String   @unique @map("quiz_id")
  criteria  Json
  weights   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  quiz      Quiz     @relation(fields: [quizId], references: [id])

  @@map("rubrics")
}

model Deadline {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime @map("due_date")
  priority    String?  @db.VarChar(50)
  courseId    String?  @map("course_id")
  unitId      String?  @map("unit_id")
  userId      String?  @map("user_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  course      Course?  @relation("CourseDeadlines", fields: [courseId], references: [id])
  unit        Unit?    @relation("UnitDeadlines", fields: [unitId], references: [id])
  user        User?    @relation("UserDeadlines", fields: [userId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([unitId])
  @@map("deadlines")
}

model UserLearningAnalytics {
  id                   String   @id @default(cuid())
  userId               String   @unique
  totalStudyTime       Int      @default(0)
  averageSessionLength Float    @default(0)
  completionRate       Float    @default(0)
  averageScore         Float    @default(0)
  currentStreak        Int      @default(0) @map("streak_days")
  longestStreak        Int      @default(0) @map("longest_streak")
  strongestSubjects    String[]
  weakestSubjects      String[]
  predictedSuccessRate Float?
  recommendedStudyTime Float?
  personalizedTips     String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_learning_analytics")
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @db.VarChar(255)
  description String?
  imageUrl    String?     @map("image_url") @db.VarChar(2048)
  criteria    Json?
  tier        String?     @db.VarChar(50)
  points      Int         @default(0)
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  users       UserBadge[] @relation("BadgeUserBadges")

  @@index([name])
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  awardedAt DateTime @default(now()) @map("awarded_at")
  metadata  Json?
  badge     Badge    @relation("BadgeUserBadges", fields: [badgeId], references: [id], onDelete: Cascade)
  user      User     @relation("UserUserBadges", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

model SystemAnalytics {
  id               String   @id @default(uuid())
  totalUsers       Int      @default(0) @map("total_users")
  activeUsers      Int      @default(0) @map("active_users")
  totalCourses     Int      @default(0) @map("total_courses")
  totalEnrollments Int      @default(0) @map("total_enrollments")
  metrics          Json?
  meta             Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("system_analytics")
}

model CourseProgress {
  id                 String         @id @default(uuid())
  userId             String         @map("user_id")
  courseId           String         @map("course_id")
  status             ProgressStatus @default(notStarted)
  progressPercentage Int            @default(0) @map("progress_percentage")
  completedUnits     Int            @default(0) @map("completed_units")
  timeSpent          Int            @default(0) @map("time_spent")
  startedAt          DateTime?      @map("started_at")
  completedAt        DateTime?      @map("completed_at")
  lastAccessedAt     DateTime       @default(now()) @map("last_accessed_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  lastUpdated        BigInt         @default(0) @map("last_updated")
  courses            Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  users              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([status])
  @@index([userId])
  @@index([userId, lastAccessedAt])
  @@index([userId, lastUpdated])
  @@map("course_progress")
}

model QuestionStats {
  id              String   @id @default(uuid())
  questionId      String   @unique @map("question_id")
  totalAttempts   Int      @default(0) @map("total_attempts")
  correctAttempts Int      @default(0) @map("correct_attempts")
  averageTime     Int      @default(0) @map("average_time")
  difficultyScore Float    @default(0) @map("difficulty_score")
  lastCalculated  DateTime @default(now()) @map("last_calculated")
  questions       Question @relation(fields: [questionId], references: [id])

  @@map("question_stats")
}

model RapidReviewAnswer {
  id                  String             @id @default(uuid())
  sessionId           String
  questionId          String
  isCorrect           Boolean
  timeSpent           Float?
  createdAt           DateTime           @default(now())
  questions           Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  rapidReviewSessions RapidReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("rapid_review_answers")
}

model RapidReviewSession {
  id                     String              @id @default(uuid())
  userId                 String
  startTime              DateTime
  endTime                DateTime
  topics                 String[]
  score                  Float
  totalQuestions         Int
  correctAnswers         Int
  averageTimePerQuestion Float
  createdAt              DateTime            @default(now())
  rapidReviewAnswers     RapidReviewAnswer[]
  users                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("rapid_review_sessions")
}

model SpacedRepetitionCard {
  id             String   @id @default(uuid())
  userId         String
  questionId     String
  easinessFactor Float    @default(2.5)
  interval       Int      @default(0)
  repetitions    Int      @default(0)
  correctStreak  Int      @default(0)
  lastReviewedAt DateTime
  nextReviewAt   DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  questions      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  users          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([nextReviewAt])
  @@index([userId])
  @@map("spaced_repetition_cards")
}

model UnitCompletion {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  unitId      String   @map("unit_id")
  completedAt DateTime @default(now()) @map("completed_at")
  score       Float?
  feedback    String?
  units       Unit     @relation(fields: [unitId], references: [id])
  users       User     @relation(fields: [userId], references: [id])

  @@unique([userId, unitId])
  @@index([unitId])
  @@index([userId])
  @@map("unit_completions")
}

model UnitProgress {
  id                 String         @id @default(uuid())
  userId             String         @map("user_id")
  unitId             String         @map("unit_id")
  status             ProgressStatus @default(notStarted)
  progressPercentage Int            @default(0) @map("progress_percentage")
  timeSpent          Int            @default(0) @map("time_spent")
  startedAt          DateTime?      @map("started_at")
  completedAt        DateTime?      @map("completed_at")
  lastAccessedAt     DateTime       @default(now()) @map("last_accessed_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  lastUpdated        BigInt         @default(0) @map("last_updated")
  units              Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  users              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId])
  @@index([status])
  @@index([unitId])
  @@index([userId])
  @@index([userId, lastAccessedAt])
  @@index([userId, lastUpdated])
  @@map("unit_progress")
}

model UserQuizProgress {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  quizId        String         @map("quiz_id")
  lastAttempted DateTime?      @map("last_attempted")
  bestScore     Float          @default(0) @map("best_score")
  attemptsCount Int            @default(0) @map("attempts_count")
  timeSpent     Int            @default(0) @map("time_spent")
  status        ProgressStatus @default(notStarted)
  quizzes       Quiz           @relation(fields: [quizId], references: [id])
  users         User           @relation(fields: [userId], references: [id])

  @@unique([userId, quizId])
  @@index([quizId])
  @@index([userId])
  @@map("user_quiz_progress")
}

model ExamMapping {
  id          String   @id @default(uuid())
  topicId     String   @map("topic_id")
  examType    ExamType @map("exam_type")
  correlation Float
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@map("exam_mappings")
}

model QuestionFlag {
  id          String   @id @default(uuid())
  questionId  String   @map("question_id")
  userId      String   @map("user_id")
  issueType   String   @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
  @@index([issueType])
  @@index([questionId, issueType])
  @@map("question_flags")
}

model PredictionAudit {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  predictionType String   @map("prediction_type") @db.VarChar(100)
  prediction     Float
  confidence     Float?
  explanation    Json?
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([predictionType])
  @@map("prediction_audits")
}

model PredictionValidation {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  topicId        String?  @map("topic_id")
  predictionDate DateTime @map("prediction_date")
  predictedScore Float    @map("predicted_score")
  actualScore    Float?   @map("actual_score")
  precision      Float?
  recall         Float?
  isCalibrated   Boolean  @default(false) @map("is_calibrated")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([predictionDate])
  @@index([isCalibrated])
  @@map("prediction_validations")
}

model InterventionExperiment {
  id             String                 @id @default(uuid())
  name           String                 @db.VarChar(255)
  description    String?
  controlGroup   String                 @default("descriptive") @map("control_group") @db.VarChar(100)
  treatmentGroup String                 @default("prescriptive") @map("treatment_group") @db.VarChar(100)
  startDate      DateTime               @map("start_date")
  endDate        DateTime?              @map("end_date")
  isActive       Boolean                @default(true) @map("is_active")
  metrics        Json?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  assignments    ExperimentAssignment[]

  @@index([isActive])
  @@map("intervention_experiments")
}

model ExperimentAssignment {
  id           String                 @id @default(uuid())
  experimentId String                 @map("experiment_id")
  userId       String                 @map("user_id")
  group        String                 @db.VarChar(50)
  outcomes     Json?
  assignedAt   DateTime               @default(now()) @map("assigned_at")
  experiment   InterventionExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([experimentId, userId])
  @@index([userId])
  @@index([experimentId])
  @@map("experiment_assignments")
}

model SkillTrajectory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  topicId    String   @map("topic_id")
  pKnown     Float    @map("p_known")
  trend      String   @default("stable") @db.VarChar(20)
  snapshotAt DateTime @default(now()) @map("snapshot_at")
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, topicId])
  @@index([snapshotAt])
  @@index([userId, snapshotAt])
  @@map("skill_trajectories")
}

model InstructorOverride {
  id           String   @id @default(uuid())
  instructorId String   @map("instructor_id")
  questionId   String   @map("question_id")
  action       String   @db.VarChar(50)
  reason       String?
  appliedAt    DateTime @default(now()) @map("applied_at")
  user         User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([instructorId])
  @@map("instructor_overrides")
}

model SyncLog {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  resourceType String    @map("resource_type") @db.VarChar(50)
  resourceId   String    @map("resource_id")
  conflictType String?   @map("conflict_type") @db.VarChar(50)
  resolution   String?   @db.VarChar(50)
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resourceType, resourceId])
  @@map("sync_logs")
}

model GlobalSearchIndex {
  id          String                   @id
  entityId    String                   @map("entity_id")
  entityType  String                   @map("entity_type")
  title       String
  description String?
  content     String?
  tags        String[]                 @default([])
  metadata    Json?
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  /// Full-text search vector for PostgreSQL tsvector queries
  fts         Unsupported("tsvector")?

  @@index([entityId])
  @@index([entityType])
  @@index([fts], type: Gin)
  @@map("global_search_index")
}

model MedicalSynonym {
  id        String   @id @default(uuid())
  term      String   @unique
  synonyms  String[]
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([term])
  @@map("medical_synonyms")
}

