# Ignore version control
.git
.gitignore
.github

# Ignore local development files
.env
.env*.local
.vscode
.vs
.vscode-extensions

# Ignore build artifacts
target/
dist/
build/
.next/
coverage/
node_modules/
.pnpm-store/

# Ignore package manager files and caches
npm-debug.log
pnpm-debug.log
yarn-error.log
.cache/

# Ignore testing and documentation
tests/
test/
*.md
README.md

# Ignore secrets and sensitive data
secrets/
*.sql
.env.*

# Ignore large binary files
*.tar.gz
*.tgz
*.zip
*.rar

# Ignore temp files
*.log
*.tmp
temp/
tmp/
**/seed-data
app.log
app_startup.log
dev_startup.log
output.log
*.log
/.pnpm
/.pnpm-store

# Ignore Python artifacts
__pycache__/
*.pyc
.venv
venv/

# Ignore Rust specific
Cargo.lock

# Ignore monitoring/infra configs not needed for builds
monitoring/
nginx/

# Large PDFs and media
*.pdf
*.mp4
*.mp3
*.mov

# misc files
*.sql
.DS_Store

